#============================================================
# FinancialFreedom - Environment Configuration Template
# Copy this file to .env and customize for your environment
#============================================================

#============================================================
# QUICK START (pilih satu opsi):
#============================================================

# Option A: Auto-detect local IP (recommended for development)
EXPO_PUBLIC_API_ENV=development
# App akan auto-detect: http://{LOCAL_IP}:8080/api

# Option B: Manual local IP (Kantor WiFi)
# EXPO_PUBLIC_API_ENV=development
# EXPO_PUBLIC_API_DEV_URL=http://10.173.85.147:8080/api

# Option C: Manual local IP (Rumah WiFi)
# EXPO_PUBLIC_API_ENV=development
# EXPO_PUBLIC_API_DEV_URL=http://192.168.1.38:8080/api

# Option D: Production
# EXPO_PUBLIC_API_ENV=production
# EXPO_PUBLIC_API_PROD_URL=https://api.financialfreedom.com/api

# Option E: Staging
# EXPO_PUBLIC_API_ENV=staging
# EXPO_PUBLIC_API_STAGING_URL=http://staging-api.financialfreedom.com:8080/api

#============================================================
# Direct Override (for quick testing, NOT for production)
#============================================================
# Uncomment to override everything above
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8080/api

#============================================================
# Firebase Google OAuth Configuration
#============================================================
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=971701431882-uqe7bbm9uulf5f7ir3t5a304j8tuu209.apps.googleusercontent.com

#============================================================
# Advanced Configuration (Optional)
#============================================================

# Custom development URL (alternative to EXPO_PUBLIC_API_DEV_URL)
# EXPO_PUBLIC_API_CUSTOM_URL=http://custom-backend:8080/api

# Custom staging URL (alternative to EXPO_PUBLIC_API_STAGING_URL)
# EXPO_PUBLIC_API_STAGING_URL=http://staging.backend.local:8080/api

# Custom production URL (alternative to EXPO_PUBLIC_API_PROD_URL)
# EXPO_PUBLIC_API_PROD_URL=https://api.financialfreedom.com/api

#============================================================
# Configuration Priority (how URL is determined):
#============================================================
# 1. EXPO_PUBLIC_API_URL (if set, uses this immediately)
# 2. EXPO_PUBLIC_API_CUSTOM_URL (if set)
# 3. Environment-specific URL based on EXPO_PUBLIC_API_ENV:
#    - development → EXPO_PUBLIC_API_DEV_URL or auto-detect IP
#    - staging → EXPO_PUBLIC_API_STAGING_URL
#    - production → EXPO_PUBLIC_API_PROD_URL
# 4. Built-in defaults (localhost, staging URL, production URL)

#============================================================
# Helpful Information
#============================================================
# 
# Find your local IP:
# Windows: Open Command Prompt → ipconfig → Look for "IPv4 Address"
# Mac/Linux: Terminal → ifconfig or hostname -I
#
# Check if backend is running:
# http://192.168.X.X:8080/api/health (if endpoint exists)
#
# Need documentation?
# See: API_CONFIG_GUIDE.md
#
#============================================================
